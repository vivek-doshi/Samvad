# =============================================================================
# Samvad — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# =============================================================================

# ── Model server ──────────────────────────────────────────────────────────────
LLAMA_SERVER_HOST=localhost
LLAMA_SERVER_PORT=8080
LLAMA_MODEL_PATH=/models/arthvidya/arthvidya-4b-q4_k_m.gguf
LLAMA_CTX_SIZE=32768
LLAMA_PARALLEL_SLOTS=4
LLAMA_GPU_LAYERS=99

# ── Embedding model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL_PATH=/models/embeddings/bge-small-en-v1.5
EMBEDDING_DEVICE=cuda

# ── Database ──────────────────────────────────────────────────────────────────
SQLITE_PATH=/runtime/sqlite/samvad.db
# Future PostgreSQL: DATABASE_URL=postgresql://user:pass@host:5432/samvad

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMADB_PATH=/runtime/chromadb
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
BCRYPT_ROUNDS=12

# ── Application ───────────────────────────────────────────────────────────────
SAMVAD_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:4200

# ── Web search (optional) ─────────────────────────────────────────────────────
WEB_SEARCH_ENABLED=false
